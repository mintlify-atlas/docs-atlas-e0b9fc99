  "keyFeatures": [
    "Adaptive AI-powered accessibility profiling (large text, high contrast, voice-assisted modes)",
    "Ethical nudging system that detects user difficulty and offers contextual help",
    "AI-based transaction risk assessment and fraud prevention",
    "SPEI-compatible money transfers and beneficiary management",
    "Open Finance integration for connecting external bank accounts",
    "Ocelot API Gateway routing all microservices through a single entry point",
    "WCAG 2.1 AA compliant UI with voice feedback and screen reader support",
    "Microservices architecture: AuthService, LedgerService, OpenFinanceService, AnalyticsService, AI Service"
  ],
